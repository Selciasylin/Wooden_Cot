 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - Wooden Cot</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        /* Minimal Custom CSS - Only for brand colors and logo */
        body {
            font-family: 'Poppins', sans-serif;
        }
        
        .logo-box {
            width: 60px;
            height: 45px;
            background-color: #8B7355;
        }
        
        .btn-custom {
            background-color: #AE946D;
            border-color: #AE946D;
        }
        
        .btn-custom:hover {
            background-color: #9a8260;
            border-color: #9a8260;
        }
        
        .footer-custom {
            background-color: #CDAF82;
        }
        
        .link-custom {
            color: #AE946D;
            text-decoration: none;
        }
        
        .link-custom:hover {
            color: #9a8260;
            text-decoration: underline;
        }
        
        .form-control:focus {
            border-color: #AE946D;
            box-shadow: 0 0 0 0.2rem rgba(174, 148, 109, 0.2);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    
    <!-- Main Content Area -->
    <div class="flex-grow-1 d-flex align-items-center justify-content-center py-4 px-3">
        <div class="bg-white rounded shadow-sm p-4" style="max-width: 420px; width: 100%;">
            
            <!-- Logo Section -->
            <div class="text-center mb-3">
                <img src="/images/logo image/wooden-cot-logo.png" alt="Wooden Cot Logo" class="img-fluid mb-2 rounded-3" style="max-width:80px;">
                <h1 class="h4 fw-semibold mb-4">SIGN IN HERE!!</h1>
            </div>
            <% if (message) { %>
                <div 
                    class="alert <%= message.type === 'success' ? 'alert-success' : 'alert-danger' %> text-center">
                    <%= message.text %>
                </div>
            <% } %>

            <!-- Google Sign In Button -->
            <button type="button" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2 mb-3" onclick="googleSignIn()">
                <svg width="18" height="18" viewBox="0 0 24 24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                <a href="/auth/google">Login with Google</a>
            </button>

            <!-- Divider -->
            <div class="text-center my-3 position-relative">
                <hr class="my-0">
                <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">or</span>
            </div>

            <!-- Sign In Form -->
            <form action="/signin" method="POST" id="signinForm" novalidate>
                <!-- Email -->
                <div class="mb-3">
                    <label for="email" class="form-label small text-secondary">Email</label>
                    <input type="email" name="email" class="form-control" id="email" placeholder="Enter your Email" required>
                     <small class="text-danger error-message"></small>
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label for="password" class="form-label small text-secondary">Password</label>
                    <input type="password" name="password" class="form-control" id="password" placeholder="Enter your password" required>
                    <small class="text-danger error-message"></small>
                </div>

                <!-- Forgot Password Link -->
                <div class="text-end mb-3">
                    <a href="/forgotPassword" class="link-custom small">Forgot Password?</a>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-custom text-white w-100 fw-semibold">SIGN IN</button>
            </form>

            <!-- Sign Up Link -->
            <div class="text-center mt-3 small text-secondary">
                Don't have an account? <a href="/signup" class="link-custom fw-semibold">Sign Up</a>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer-custom text-white py-3 mt-auto">
        <p class="text-center small mb-0 opacity-75">© 2024 WOODEN COT. All Rights Reserved.</p>
    </footer>
    <!-- Verify Account Modal -->
<div class="modal fade" id="verifyModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-3 shadow">

      <div class="modal-header border-0">
        <h5 class="modal-title fw-semibold">Account Not Verified</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body text-center">
        <p class="text-secondary">
          You have signed up but not verified your account.
          Please verify to continue.
        </p>
      </div>

      <div class="modal-footer border-0 justify-content-center gap-2">
        <button type="button" id="verifyBtn" class="btn btn-success px-4">Verify</button>
        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
      </div>

    </div>
  </div>
</div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Form Validation and Google Sign In Scripts -->
    <script>
        document.getElementById("signinForm").addEventListener("submit", async function (e) {
            e.preventDefault(); // stop normal submit
            const form = this;
            let isValid = true;
            form.querySelectorAll(".error-message").forEach(el => el.textContent = "");
            const email = form.email.value.trim();
            const password = form.password.value.trim();
            const emailPattern = /^[^ ]+@[^ ]+\.[a-z]{2,3}$/;
            if (email === "") {
                showError(form.email, "Email is required");
                isValid = false;
            } else if (!emailPattern.test(email)) {
                showError(form.email, "Enter a valid email");
                isValid = false;
            }
            if (password === "") {
                showError(form.password, "Password is required");
                isValid = false;
            } else if (password.length < 6) {
                showError(form.password, "Password must be at least 6 characters");
                isValid = false;
            }
            if (!isValid) return; // stop if validation fails
            // FETCH STARTS HERE
            const response = await fetch("/signin", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    email: form.email.value,
                    password: form.password.value
                })
            });
            const data = await response.json();
            if (data.status === "SUCCESS") {
                window.location.href = "/";
            }
            if (data.status === "NOT_VERIFIED") {
                const verifyModal = new bootstrap.Modal(
                    document.getElementById("verifyModal")
                );
                verifyModal.show();
            }
            if (data.status === "ERROR") {
                showTopError(data.message);
            }
            function showError(input, message) {
                input.nextElementSibling.textContent = message;
            }
            function showTopError(message) {
                const alertDiv = document.createElement("div");
                alertDiv.className = "alert alert-danger text-center";
                alertDiv.innerText = message;
                const card = document.querySelector(".bg-white");
                card.prepend(alertDiv);
                setTimeout(() => alertDiv.remove(), 2000);
            }
        });
        const verifyBtn = document.getElementById("verifyBtn");
            if (verifyBtn) {
                verifyBtn.addEventListener("click", async function () {
                    // Prevent double click
                    verifyBtn.disabled = true;
                    try {
                        const response = await fetch("/resendSignupOtp", {
                            method: "POST"
                        });
                        const data = await response.json();
                        if (data.status === "OTP_SENT") {
                            window.location.href = "/verifyOtp";
                        } else {
                            alert("Failed to send OTP");
                            verifyBtn.disabled = false;
                        }
                    } catch (error) {
                        alert("Something went wrong");
                        verifyBtn.disabled = false;
                    }
                }, { once: true });  // 🔥 VERY IMPORTANT
            }
    </script>

</body>
</html>