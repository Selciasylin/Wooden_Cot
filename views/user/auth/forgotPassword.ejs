<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Wooden Cot</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        /* Minimal Custom CSS - Only for brand colors and logo */
        body {
            font-family: 'Poppins', sans-serif;
        }
        
        .logo-box {
            width: 60px;
            height: 45px;
            background-color: #8B7355;
        }
        
        .btn-custom {
            background-color: #AE946D;
            border-color: #AE946D;
        }
        
        .btn-custom:hover {
            background-color: #9a8260;
            border-color: #9a8260;
        }
        
        .footer-custom {
            background-color: #CDAF82;
        }
        
        .link-custom {
            color: #AE946D;
            text-decoration: none;
        }
        
        .link-custom:hover {
            color: #9a8260;
            text-decoration: underline;
        }
        
        .form-control:focus {
            border-color: #AE946D;
            box-shadow: 0 0 0 0.2rem rgba(174, 148, 109, 0.2);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    
    <!-- Main Content Area -->
    <div class="flex-grow-1 d-flex align-items-center justify-content-center py-4 px-3">
        <div class="bg-white rounded shadow-sm p-4" style="max-width: 420px; width: 100%;">
            
            <!-- Logo Section -->
            <div class="text-center mb-3">
                <div class="logo-box mx-auto mb-3 rounded"></div>
                <h1 class="h4 fw-semibold mb-2">FORGOT PASSWORD</h1>
                <p class="text-muted small mb-4">Enter your email address and we'll send you an OTP to reset your password.</p>
            </div>
            <% if (message) { %>
            <div 
                class="alert <%= message.type === 'success' ? 'alert-success' : 'alert-danger' %> text-center">
                <%= message.text %>
            </div>
            <% } %>

            <!-- Forgot Password Form -->
            <form action="/forgotPassword" method="POST" id="forgotPasswordForm" novalidate>
                <!-- Email -->
                <div class="mb-3">
                    <label for="email" class="form-label small text-secondary">Email</label>
                    <input type="email" name="email" class="form-control" id="email" placeholder="Enter your Email">
                     <small class="text-danger error-message"></small>
                </div>

                <!-- Send OTP Button -->
                <button type="submit" class="btn btn-custom text-white w-100 fw-semibold">SEND OTP</button>
            </form>

            <!-- Back to Sign In Link -->
            <div class="text-center mt-3 small text-secondary">
                Remember your password? <a href="signin.html" class="link-custom fw-semibold">Sign In</a>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer-custom text-white py-3 mt-auto">
        <p class="text-center small mb-0 opacity-75">© 2024 WOODEN COT. All Rights Reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Form Validation Script -->
    <script>
        const alertBox = document.querySelector(".alert");
        if (alertBox) {
            setTimeout(() => {
                alertBox.style.display = "none";
            }, 2000);
        }
        document.getElementById("forgotPasswordForm").addEventListener("submit", function (e) {

            const form = this;
            let isValid = true;

            // Clear previous errors
            form.querySelectorAll(".error-message")
                .forEach(el => el.textContent = "");

            // Email Validation
            const email = form.email.value.trim();
            const emailPattern = /^[^ ]+@[^ ]+\.[a-z]{2,3}$/;

            if (email === "") {
                showError(form.email, "Email is required");
                isValid = false;
            }
            else if (!emailPattern.test(email)) {
                showError(form.email, "Enter a valid email address");
                isValid = false;
            }

            if (!isValid) {
                e.preventDefault(); // Stop submit only if invalid
            }

            function showError(input, message) {
                const errorElement = input.nextElementSibling;
                errorElement.textContent = message;
            }

        });
    </script>  
</body>
</html>