 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wooden Cot - Home</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* Minimal Custom CSS */
        body {
            font-family: 'Poppins', sans-serif;
        }
        
        .navbar-custom {
            background-color: #AE946D;
        }
        
        .btn-custom {
            background-color: #AE946D;
            border-color: #AE946D;
            color: white;
        }
        
        .btn-custom:hover {
            background-color: #9a8260;
            border-color: #9a8260;
            color: white;
        }
        
        .footer-custom {
            background-color: #CDAF82;
        }
        
        .hero-section {
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1200');
            background-size: cover;
            background-position: center;
            min-height: 400px;
            color: white;
        }
        
        @media (min-width: 768px) {
            .hero-section {
                min-height: 500px;
            }
        }
        
        @media (min-width: 1200px) {
            .hero-section {
                min-height: 600px;
            }
        }
        
        .material-circle {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            overflow: hidden; /* Important */
            margin: 0 auto;
        }

        .material-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Makes image perfectly fit */
        }

        
        @media (min-width: 768px) {
            .material-circle {
                width: 120px;
                height: 120px;
            }
        }

        
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
        
        .product-card {
            transition: all 0.3s ease;
        }
        
        .price-original {
            text-decoration: line-through;
            color: #999;
        }
        
        .discount-badge {
            background-color: #dc3545;
            color: white;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
        }
        
        .best-seller-section {
            background-color: #C9A876;
            min-height: 300px;
        }
        
        @media (min-width: 768px) {
            .best-seller-section {
                min-height: 400px;
            }
        }
        
        @media (min-width: 1200px) {
            .best-seller-section {
                min-height: 500px;
            }
        }
        
        .logo-text {
            font-weight: 700;
            font-size: 24px;
            color: white;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
