<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Wooden Cot</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }

        .logo-box {
            width: 60px;
            height: 45px;
            background-color: #8B7355;
        }

        .btn-custom {
            background-color: #AE946D;
            border-color: #AE946D;
        }

        .btn-custom:hover {
            background-color: #9a8260;
            border-color: #9a8260;
        }

        .footer-custom {
            background-color: #CDAF82;
        }

        .link-custom {
            color: #AE946D;
            text-decoration: none;
        }

        .link-custom:hover {
            color: #9a8260;
            text-decoration: underline;
        }

        .form-control:focus {
            border-color: #AE946D;
            box-shadow: 0 0 0 0.2rem rgba(174, 148, 109, 0.2);
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100 bg-light">

<div class="flex-grow-1 d-flex align-items-center justify-content-center py-3 px-3">
    <div class="bg-white rounded shadow-sm p-3 py-4" style="max-width: 420px; width: 100%;">

        <!-- Logo Section -->
        <div class="text-center mb-3">
            <div class="logo-box mx-auto mb-2 rounded"></div>
            <h1 class="h5 fw-semibold mb-3">SIGN UP HERE!!</h1>
        </div> 
        <% if (message) { %>
            <div 
                class="alert <%= message.type === 'success' ? 'alert-success' : 'alert-danger' %> text-center">
                <%= message.text %>
            </div>
        <% } %>

        <!-- Google Sign Up Button -->
        <button type="button"
            class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2 mb-3 py-2">
            <!-- Google Logo SVG -->
            <svg width="18" height="18" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <a href="/auth/google">Login with Google</a>
        </button>
        
        <div class="text-center my-3 position-relative">
            <hr class="my-0">
            <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">or</span>
        </div>

        <!-- Sign Up Form -->
        <form action="/signup" method="POST" id="signupForm" novalidate>

            <!-- First Name -->
            <div class="mt-2">
                <label class="form-label small text-secondary mb-1">First Name</label>
                <input type="text" name="firstName" class="form-control form-control-sm" placeholder="Enter your First Name" required>
                <small class="text-danger error-message"></small>
            </div>

            <!-- Last Name -->
            <div class="mt-2">
                <label class="form-label small text-secondary mb-1">Last Name</label>
                <input type="text" name="lastName" class="form-control form-control-sm" placeholder="Enter your Last Name" required>
                <small class="text-danger error-message"></small>
            </div>

            <!-- Email -->
            <div class="mt-2">
                <label class="form-label small text-secondary mb-1">Email</label>
                <input type="email" name="email" class="form-control form-control-sm" placeholder="Enter your Email" required>
                <small class="text-danger error-message"></small>
            </div>

            <!-- Phone -->
            <div class="mt-2">
                <label class="form-label small text-secondary mb-1">PhoneNumber</label>
                <input type="tel" name="phoneNumber" class="form-control form-control-sm" placeholder="Enter your Number" required>
                <small class="text-danger error-message"></small>
            </div>

            <!-- Password -->
            <div class="mt-2">
                <label class="form-label small text-secondary mb-1">Password</label>
                <input type="password" name="password" class="form-control form-control-sm" placeholder="Enter your password" required>
                <small class="text-danger error-message"></small>
            </div>

            <!-- Referral Code -->
            <div class="mt-2">
                <label class="form-label small text-secondary mb-1">Referral Code</label>
                <input type="text" name="referralCode" class="form-control form-control-sm" placeholder="Enter Referral Code">
                <small class="text-danger error-message"></small>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-custom text-white w-100 fw-semibold mt-3 py-2">
                SIGN UP
            </button>

        </form>

        <!-- Sign In Link -->
        <div class="text-center mt-3 small text-secondary">
            Already have an account?
            <a href="/signin" class="link-custom fw-semibold">Sign In</a>
        </div>

    </div>
</div>

<!-- Footer -->
<footer class="footer-custom text-white py-3 mt-auto">
    <p class="text-center small mb-0 opacity-75">© 2024 WOODEN COT. All Rights Reserved.</p>
</footer> 

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.getElementById("signupForm").addEventListener("submit", function (e) {

    const form = this;
    const inputs = form.querySelectorAll("input");
    let isValid = true;

    // Clear previous errors
    form.querySelectorAll(".error-message").forEach(el => el.textContent = "");

     // First Name Validation
const firstName = form.firstName.value.trim();
if (firstName === "") {
    showError(form.firstName, "First name is required");
    isValid = false;
} else if (!/^[A-Za-z]+$/.test(firstName)) {
    showError(form.firstName, "First name should contain only letters");
    isValid = false;
}

// Last Name Validation
const lastName = form.lastName.value.trim();
if (lastName === "") {
    showError(form.lastName, "Last name is required");
    isValid = false;
} else if (!/^[A-Za-z]+$/.test(lastName)) {
    showError(form.lastName, "Last name should contain only letters");
    isValid = false;
}

// Email Validation
const email = form.email.value.trim();
const emailPattern = /^[^ ]+@[^ ]+\.[a-z]{2,3}$/;
if (email === "") {
    showError(form.email, "Email is required");
    isValid = false;
} else if (!emailPattern.test(email)) {
    showError(form.email, "Enter a valid email address");
    isValid = false;
}

// Phone Validation
const phone = form.phoneNumber.value.trim();
if (phone === "") {
    showError(form.phoneNumber, "Phone number is required");
    isValid = false;
} else if (!/^[0-9]{10}$/.test(phone)) {
    showError(form.phoneNumber, "Phone must be 10 digits");
    isValid = false;
}

// Password Validation
const password = form.password.value.trim();
if (password === "") {
    showError(form.password, "Password is required");
    isValid = false;
} else if (!/^(?=.*\d).{6,}$/.test(password)) {
    showError(form.password, "Password must be 6+ chars and include a number");
    isValid = false;
}

    if (!isValid) {
        e.preventDefault(); // Stop form submit only if invalid
    }

    function showError(input, message) {
        const errorElement = input.nextElementSibling;
        errorElement.textContent = message;
    }

});
</script>


</body>
</html>
